APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=18000
LOG_LEVEL=INFO
# Local Docker Compose host binding. Keep 127.0.0.1 unless you intentionally
# want to expose local services to your LAN/VPN.
LOCAL_BIND_HOST=127.0.0.1
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=projectrag
POSTGRES_USER=projectrag
POSTGRES_PASSWORD=change-me-local-only
GRAPHDB_URL=http://localhost:7200
GRAPHDB_REPOSITORY=projectrag
GRAPHDB_ENSURE_REPOSITORY_ON_STARTUP=true
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
EMBEDDING_MODEL=nomic-embed-text
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K=5
MAX_UPLOAD_SIZE_BYTES=5242880
MAX_UPLOAD_FILES_PER_REQUEST=1
USE_LLM_ROUTER=false
GRAPH_MAX_DEPTH=3
USE_LLM_JUDGE=false

# Local gateway controls. Docker Compose defaults to this dev key when unset.
PROJECTRAG_API_KEY=local-dev-key
PROJECTRAG_AUTH_REQUIRED=true
PROJECTRAG_AUTH_MODE=local
PROJECTRAG_RATE_LIMIT_PER_MINUTE=0
# Per-endpoint rate limits (JSON: {"POST /ingest": 5, "POST /query": 10})
PROJECTRAG_RATE_LIMIT_PER_ENDPOINT={}
PROJECTRAG_REQUEST_AUDIT_ENABLED=true
PROJECTRAG_ENFORCE_RBAC=true
PROJECTRAG_LOCAL_USER=local-dev
PROJECTRAG_LOCAL_ROLE=admin
PROJECTRAG_LOCAL_TENANT=local

# Non-local startup guard: production, staging, and dev must configure at least one auth method.
# Option A: API key auth (set PROJECTRAG_API_KEY_HASH; plaintext PROJECTRAG_API_KEY is deprecated)
# Option B: OIDC auth (set PROJECTRAG_AUTH_MODE=oidc, PROJECTRAG_OIDC_ISSUER, PROJECTRAG_OIDC_AUDIENCE)
# Optional OIDC JWKS override: PROJECTRAG_OIDC_JWKS_URL

# Redis cache / rate-limit backend
REDIS_URL=redis://localhost:6379/0

# Qdrant vector index
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=projectrag_chunks

# OpenTelemetry
OTEL_ENABLED=false
OTEL_SERVICE_NAME=projectrag-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# Grafana local credentials
GRAFANA_ADMIN_USER=change-me
GRAFANA_ADMIN_PASSWORD=change-me

# Local observability host ports (avoid conflicts with system services)
PROMETHEUS_PORT=9091
ALERTMANAGER_PORT=9094

# Alertmanager config override file (recommended: local untracked file with real webhooks/secrets)
# ALERTMANAGER_CONFIG_PATH=./deploy/monitoring/alertmanager/alertmanager.local.yml

# Live cloud connector safety gate. Keep false until ready for real cloud discovery.
PROJECTRAG_CLOUD_CONNECTORS_ENABLED=false
