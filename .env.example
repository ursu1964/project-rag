APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=projectrag
POSTGRES_USER=projectrag
POSTGRES_PASSWORD=change-me-local-only
GRAPHDB_URL=http://localhost:7200
GRAPHDB_REPOSITORY=projectrag
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
EMBEDDING_MODEL=nomic-embed-text
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K=5
USE_LLM_ROUTER=false
GRAPH_MAX_DEPTH=3
USE_LLM_JUDGE=false

# Optional local gateway controls. Leave API key empty to disable auth in local dev.
PROJECTRAG_API_KEY=
PROJECTRAG_RATE_LIMIT_PER_MINUTE=0
PROJECTRAG_REQUEST_AUDIT_ENABLED=true
PROJECTRAG_ENFORCE_RBAC=false

# Redis cache / rate-limit backend
REDIS_URL=redis://localhost:6379/0

# Qdrant vector index
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=projectrag_chunks

# OpenTelemetry
OTEL_ENABLED=false
OTEL_SERVICE_NAME=projectrag-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# Live cloud connector safety gate. Keep false until ready for real cloud discovery.
ENABLE_CLOUD_CONNECTORS=false
