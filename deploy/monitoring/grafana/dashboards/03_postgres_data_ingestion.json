    {
      "id": 7,
      "title": "Documents ingested over time",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "projectrag-postgres"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "projectrag-postgres"
          },
          "format": "time_series",
          "rawSql": "SELECT $__timeGroupAlias(created_at, '5m'), count(*) AS documents FROM documents WHERE $__timeFilter(created_at) GROUP BY 1 ORDER BY 1",
          "rawQuery": true
        }
      ]
    },
    {
      "id": 8,
      "title": "Chunks created over time",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "datasource": {
        "type": "postgres",
