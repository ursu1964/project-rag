          },
          "format": "time_series",
          "rawSql": "SELECT $__timeGroupAlias(created_at, '5m'), count(*) AS chunks FROM chunks WHERE $__timeFilter(created_at) GROUP BY 1 ORDER BY 1",
          "rawQuery": true
        }
      ]
    },
    {
      "id": 9,
      "title": "Recent documents from PostgreSQL",
      "type": "table",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "postgres",
        "uid": "projectrag-postgres"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "projectrag-postgres"
          },
          "format": "table",
          "rawSql": "SELECT created_at AS time, id::text, source, COALESCE(metadata->>'tenant_id','local') AS tenant_id, left(file_hash, 16) AS file_hash_prefix FROM documents ORDER BY created_at DESC LIMIT 25",
          "rawQuery": true
        }
      ],
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 10,
      "title": "Chunks by document",
      "type": "table",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "datasource": {
        "type": "postgres",
        "uid": "projectrag-postgres"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "projectrag-postgres"
          },
          "format": "table",
          "rawSql": "SELECT d.source, count(c.id) AS chunks, min(c.created_at) AS first_chunk_at, max(c.created_at) AS last_chunk_at FROM documents d LEFT JOIN chunks c ON c.document_id = d.id GROUP BY d.id, d.source ORDER BY chunks DESC, d.source LIMIT 25",
          "rawQuery": true
        }
      ],
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 11,
      "title": "Graph facts extracted from ingested data",
      "type": "table",
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 21
      },
      "datasource": {
        "type": "postgres",
        "uid": "projectrag-postgres"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "projectrag-postgres"
          },
          "format": "table",
          "rawSql": "SELECT gf.created_at AS time, gf.subject, gf.predicate, gf.object, round(gf.confidence::numeric, 2) AS confidence, d.source AS source_document FROM graph_facts gf LEFT JOIN documents d ON d.id = gf.source_document_id ORDER BY gf.created_at DESC LIMIT 50",
          "rawQuery": true
        }
      ],
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 12,
      "title": "Recent Ask AI / workflow runs",
      "type": "table",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 30
      },
      "datasource": {
        "type": "postgres",
        "uid": "projectrag-postgres"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "projectrag-postgres"
          },
          "format": "table",
          "rawSql": "SELECT created_at AS time, workflow_name, status, COALESCE(input->>'question', input->>'query', left(input::text, 120)) AS question, error FROM workflow_runs ORDER BY created_at DESC LIMIT 30",
          "rawQuery": true
        }
      ],
      "options": {
        "showHeader": true
      }
    },
