{
  "id": null,
  "uid": "projectrag-ingestion",
  "title": "ProjectRAG - Ingestion Throughput and Failures",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "refresh": "15s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Ingestion throughput (runs/min)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "60 * rate(projectrag_ingestions_total[5m])"}]
    },
    {
      "id": 2,
      "title": "Ingestion failures (failures/min)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "60 * rate(projectrag_ingestion_failures_total[5m])"}]
    },
    {
      "id": 3,
      "title": "Ingestion failure rate (%)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "100 * rate(projectrag_ingestion_failures_total[5m]) / clamp_min(rate(projectrag_ingestions_total[5m]), 0.0001)"
        }
      ]
    }
  ]
}
