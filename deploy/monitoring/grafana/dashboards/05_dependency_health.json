{
  "id": null,
  "uid": "projectrag-dependencies",
  "title": "ProjectRAG - Dependency Health",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "refresh": "15s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "PostgreSQL TCP health",
      "type": "stat",
      "gridPos": {"h": 5, "w": 8, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "max(probe_success{job='blackbox_tcp',instance='postgres:5432'})"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "background", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 2,
      "title": "GraphDB HTTP health",
      "type": "stat",
      "gridPos": {"h": 5, "w": 8, "x": 8, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "max(probe_success{job='blackbox_http',instance='http://graphdb:7200/rest/repositories'})"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "background", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 3,
      "title": "Ollama HTTP health",
      "type": "stat",
      "gridPos": {"h": 5, "w": 8, "x": 16, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "max(probe_success{job='blackbox_http',instance='http://host.docker.internal:11434/api/tags'})"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "background", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 4,
      "title": "Dependency probe success over time",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "probe_success{job='blackbox_http'}"},
        {"refId": "B", "expr": "probe_success{job='blackbox_tcp'}"}
      ]
    }
  ]
}
