{
  "id": null,
  "uid": "projectrag-workflow-agents",
  "title": "ProjectRAG - Workflow and Agent Performance",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "refresh": "15s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Workflow run rate by status (runs/min)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "60 * sum by (status) (rate(projectrag_workflow_runs_total[5m]))"
        }
      ]
    },
    {
      "id": 2,
      "title": "Agent run rate by agent/status (runs/min)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "60 * sum by (agent_name, status) (rate(projectrag_agent_runs_total[5m]))"
        }
      ]
    },
    {
      "id": 3,
      "title": "Agent latency p95 by agent (ms)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, agent_name) (rate(projectrag_agent_run_latency_ms_bucket[5m])))"
        }
      ]
    },
    {
      "id": 4,
      "title": "Workflow duration p95 (ms)",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(projectrag_workflow_duration_ms_bucket[5m])) by (le))"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 5,
      "title": "Vector retrieval latency p95 (ms)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(projectrag_vector_retrieval_ms_bucket[5m])) by (le))"
        }
      ]
    },
    {
      "id": 6,
      "title": "LLM call latency p95 by operation/model (ms)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, operation, model) (rate(projectrag_llm_call_latency_ms_bucket[5m])))"
        }
      ]
    },
    {
      "id": 7,
      "title": "LLM call errors by operation/model (errors/min)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "60 * sum by (operation, model) (rate(projectrag_llm_call_errors_total[5m]))"
        }
      ]
    }
  ]
}
