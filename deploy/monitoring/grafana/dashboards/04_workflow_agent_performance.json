          "datasource": {
            "type": "postgres",
            "uid": "projectrag-postgres"
          },
          "format": "table",
          "rawSql": "SELECT count(*) AS value FROM agent_runs",
          "rawQuery": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
