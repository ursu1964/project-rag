      }
    },
    {
      "id": 22,
      "title": "PostgreSQL graph facts",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 20
      },
      "datasource": {
        "type": "postgres",
        "uid": "projectrag-postgres"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "projectrag-postgres"
          },
          "format": "table",
          "rawSql": "SELECT count(*) AS value FROM graph_facts",
          "rawQuery": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
