{
  "id": null,
  "uid": "projectrag-health",
  "title": "ProjectRAG - Health and Availability",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "refresh": "15s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "API scrape up",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "max(up{job='projectrag_api'})"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "background", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 2,
      "title": "API /health probe",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "max(probe_success{job='blackbox_http',instance='http://api:8000/health'})"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "background", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 3,
      "title": "API /health/deep probe",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "max(probe_success{job='blackbox_http',instance='http://api:8000/health/deep'})"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "background", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 4,
      "title": "Request rate (req/s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "sum(rate(projectrag_http_requests_total[5m]))"}]
    },
    {
      "id": 5,
      "title": "Availability over time (%)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "avg_over_time(probe_success{job='blackbox_http',instance='http://api:8000/health'}[5m]) * 100"
        }
      ]
    }
  ]
}
